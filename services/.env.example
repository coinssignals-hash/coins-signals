# =============================================================================
# Trading Signals Platform - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# DATABASE (TimescaleDB/PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_secret_2024
POSTGRES_DB=trading_signals
DB_HOST=db
DB_PORT=5432

# Connection string (constructed from above, used by app)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# -----------------------------------------------------------------------------
# API SERVICE
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# REALTIME SERVICE
# -----------------------------------------------------------------------------
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8001

# -----------------------------------------------------------------------------
# WORKER SERVICE
# -----------------------------------------------------------------------------
WORKER_INTERVAL_SECONDS=5
WORKER_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
